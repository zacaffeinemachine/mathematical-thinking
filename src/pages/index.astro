---
import Base from "../layouts/Base.astro";
import ChapterCard from "../components/ChapterCard.astro";
import { isChapterVisible } from "../config/visibility.ts";

const base = import.meta.env.BASE_URL;

// Hand-curated chapter list — order and blurbs matter pedagogically.
// Visibility is controlled in src/config/visibility.ts.
const allChapters = [
  {
    slug: "guarini",
    title: "Guarini's Puzzle",
    blurb: "Four knights on a 3×3 board. Can they trade places? A 500-year-old puzzle that teaches us to think in graphs.",
  },
  {
    slug: "logical-thinking",
    title: "Logical Thinking",
    blurb: "Puzzles in reasoning, starting with the four cards that catch almost everyone off guard.",
  },
  {
    slug: "machines",
    title: "Machines",
    blurb: "A few circles, a few arrows, a tape of symbols. Watch a finite state machine react — and find the patterns it provably cannot recognise.",
  },
  {
    slug: "boolean-algebra",
    title: "Boolean Algebra",
    blurb: "Two values, two operations, a half-dozen identities. Every equation is a logical claim in disguise — and the algebra does the case analysis for us.",
  },
  {
    slug: "logic-gates",
    title: "Logic Gates",
    blurb: "Rods, sleeves, and levers — can you build a machine that thinks? A computer, piece by mechanical piece.",
  },
  {
    slug: "infinity",
    title: "Infinity",
    blurb: "A frog the shooter cannot miss, a hotel that always has room, and a book whose every page lists pages of itself. Some infinities are bigger than others.",
  },
  {
    slug: "permutations",
    title: "Permutations",
    blurb: "Gemstones in numbered slots and a single accounting trick — slots minus cycles — that proves the 15 puzzle's prize unwinnable.",
  },
  // More chapters will be added here as they're built.
];

const chapters = allChapters.filter((c) => isChapterVisible(c.slug));
---
<Base title="Mathematical Thinking" description="A puzzle-driven course in how mathematicians think.">
  <section class="mb-16">
    <h1 class="text-4xl font-semibold tracking-tight mb-4">Mathematical Thinking</h1>
    <p class="prose text-lg text-[var(--muted)]">
      A course taught through puzzles. Each chapter presents a question that looks simple,
      resists solution, and rewards you with a new way of thinking.
    </p>
  </section>

  <section class="grid gap-4 md:grid-cols-2">
    {chapters.map((c, i) => (
      <ChapterCard
        href={`${base}/${c.slug}/`}
        title={c.title}
        blurb={c.blurb}
        number={i + 1}
      />
    ))}
  </section>
</Base>
